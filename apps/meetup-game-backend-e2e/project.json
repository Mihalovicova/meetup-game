{
  "name": "meetup-game-backend-e2e",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "implicitDependencies": ["meetup-game-backend"],
  "targets": {
    "e2e": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{e2eProjectRoot}"],
      "options": {
        "jestConfig": "apps/meetup-game-backend-e2e/jest.config.cts",
        "passWithNoTests": true
      },
      "dependsOn": ["meetup-game-backend:build", "meetup-game-backend:serve"]
    }
  }
}
